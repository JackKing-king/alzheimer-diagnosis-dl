# ============================================================
# 第六部分: 训练模型
# ============================================================

import os

# 配置训练参数
MODEL = "cnn"  # 可选: cnn, resnet, efficientnet, vit
EPOCHS = 50
BATCH_SIZE = 32
LEARNING_RATE = 1e-4

# 创建输出目录
OUTPUT_DIR = f"/content/drive/MyDrive/alzheimer-results/{MODEL}"
!mkdir -p {OUTPUT_DIR}

# 开始训练
if MODEL == "cnn":
    !python training/train_cnn.py \
        --data_dir data/splits \
        --output_dir {OUTPUT_DIR} \
        --model_name resnet50 \
        --epochs {EPOCHS} \
        --batch_size {BATCH_SIZE} \
        --lr {LEARNING_RATE} \
        --num_workers 2 \
        --pretrained \
        --use_class_weights
        
elif MODEL == "resnet":
    !python training/train_resnet.py \
        --data_dir data/splits \
        --output_dir {OUTPUT_DIR} \
        --model_name resnet101 \
        --epochs {EPOCHS} \
        --batch_size {BATCH_SIZE} \
        --lr {LEARNING_RATE} \
        --num_workers 2 \
        --pretrained \
        --use_class_weights
        
elif MODEL == "efficientnet":
    !python training/train_efficientnet.py \
        --data_dir data/splits \
        --output_dir {OUTPUT_DIR} \
        --model_name efficientnet_b0 \
        --epochs {EPOCHS} \
        --batch_size {BATCH_SIZE} \
        --lr {LEARNING_RATE} \
        --num_workers 2 \
        --pretrained \
        --use_class_weights
        
elif MODEL == "vit":
    !python training/train_vit.py \
        --data_dir data/splits \
        --output_dir {OUTPUT_DIR} \
        --model_name vit_base_patch16_224 \
        --epochs {EPOCHS} \
        --batch_size 16 \
        --lr {LEARNING_RATE} \
        --num_workers 2 \
        --pretrained \
        --use_class_weights

print(f"训练完成！结果保存在: {OUTPUT_DIR}")

# ============================================================
# 第七部分: 评估模型
# ============================================================

# 运行评估
!python evaluation/evaluate.py \
    --model_path {OUTPUT_DIR}/checkpoints/best_model.pth \
    --data_dir data/splits \
    --output_dir {OUTPUT_DIR}/evaluation \
    --model_type {MODEL}

# ============================================================
# 第八部分: 可视化训练结果
# ============================================================

import json
import matplotlib.pyplot as plt
import numpy as np

# 加载训练历史
history_path = f"{OUTPUT_DIR}/history.json"
with open(history_path, 'r') as f:
    history = json.load(f)

# 绘制训练曲线
fig, axes = plt.subplots(2, 2, figsize=(15, 10))

# Loss
axes[0, 0].plot(history['train_loss'], label='Train Loss')
axes[0, 0].plot(history['val_loss'], label='Val Loss')
axes[0, 0].set_title('Loss')
axes[0, 0].set_xlabel('Epoch')
axes[0, 0].set_ylabel('Loss')
axes[0, 0].legend()
axes[0, 0].grid(True)

# Accuracy
axes[0, 1].plot(history['train_acc'], label='Train Acc')
axes[0, 1].plot(history['val_acc'], label='Val Acc')
axes[0, 1].set_title('Accuracy')
axes[0, 1].set_xlabel('Epoch')
axes[0, 1].set_ylabel('Accuracy (%)')
axes[0, 1].legend()
axes[0, 1].grid(True)

plt.tight_layout()
plt.savefig(f"{OUTPUT_DIR}/training_curves.png", dpi=150)
plt.show()

print(f"训练曲线已保存到: {OUTPUT_DIR}/training_curves.png")

